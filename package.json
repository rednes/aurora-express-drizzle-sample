{
  "name": "aurora-express-drizzle-sample",
  "version": "1.0.0",
  "description": "Aurora PostgreSQL Serverless Express + Drizzle ORM sample",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
